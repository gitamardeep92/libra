# ─── Database (AWS RDS PostgreSQL) ───────────────────────────────────────────
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=libra
DB_USER=libra_admin
DB_PASSWORD=your_strong_password_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_very_long_random_secret_min_64_chars_here_change_this
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your CloudFront domain or custom domain
ALLOWED_ORIGINS=https://your-cloudfront-domain.cloudfront.net,https://yourdomain.com
